/**
  * @brief  The application entry point.
  * @retval int
  */
int main(void)
{

  /* USER CODE BEGIN 1 */

  /* USER CODE END 1 */

  /* MCU Configuration--------------------------------------------------------*/

  /* Reset of all peripherals, Initializes the Flash interface and the Systick. */
  HAL_Init();

  /* USER CODE BEGIN Init */

  /* USER CODE END Init */

  /* Configure the system clock */
  SystemClock_Config();

  /* USER CODE BEGIN SysInit */

  /* USER CODE END SysInit */

  /* Initialize all configured peripherals */
  MX_GPIO_Init();
  MX_USART2_UART_Init();
  MX_TIM1_Init();
  /* USER CODE BEGIN 2 */
  HAL_TIM_PWM_Start(&htim1,TIM_CHANNEL_2);
  int n = 0;
  int fréquence[3] = {1000,500,250};
  int pinstate1 = 0;

  static GPIO_PinState previousState1 = GPIO_PIN_RESET;
  static uint32_t lastBlinkTime = 0;

  /* USER CODE END 2 */

  /* Infinite loop */
  /* USER CODE BEGIN WHILE */
  while (1)
    {
      /* USER CODE END WHILE */

      /* USER CODE BEGIN 3 */
  	  // Détection du front montant pour BT1 (mode)
  	  GPIO_PinState state1 = HAL_GPIO_ReadPin(GPIOA, BT1_Pin);//D12 (PB_4)
  	  if (state1 == GPIO_PIN_SET && previousState1 == GPIO_PIN_RESET) {
  	      pinstate1 = !pinstate1; // Bascule le mode
  	  }
  	  previousState1 = state1;

  	  // Détection du front montant pour BT2 (fréquence)
  	  GPIO_PinState state2 = HAL_GPIO_ReadPin(GPIOB, BT2_Pin);//A6 (PA_7)
  	  if (state2 == GPIO_PIN_SET) {
  	      n = (n + 1) % 3; // Cycle entre 0, 1, 2
  	      HAL_Delay(200); // Anti-rebond logiciel
  	  }

  	  // Gestion non-bloquante des LEDs
  	  uint32_t currentTime = HAL_GetTick();
  	  if (currentTime - lastBlinkTime >= fréquence[n])
  	      lastBlinkTime = currentTime;{
  		  if (pinstate1 == 0){

  			  HAL_GPIO_WritePin(GPIOB, LED_V_Pin, GPIO_PIN_SET);
  			  HAL_Delay(fréquence[n]);
  			  HAL_GPIO_WritePin(GPIOB, LED_V_Pin, GPIO_PIN_RESET);
  			  HAL_GPIO_WritePin(GPIOB, LED_J_Pin, GPIO_PIN_SET);
  			  HAL_Delay(fréquence[n]);
  			  HAL_GPIO_WritePin(GPIOB, LED_J_Pin, GPIO_PIN_RESET);
  			  HAL_GPIO_WritePin(GPIOB, LED_R_Pin, GPIO_PIN_SET);
  			  HAL_Delay(fréquence[n]);
  			  HAL_GPIO_WritePin(GPIOB, LED_R_Pin, GPIO_PIN_RESET);
  			  HAL_GPIO_WritePin(GPIOA, LED_B_Pin, GPIO_PIN_SET);
  			  HAL_Delay(fréquence[n]);
  			  HAL_GPIO_WritePin(GPIOA, LED_B_Pin, GPIO_PIN_RESET);
  		  }

  		  if (pinstate1 == 1){
  			  HAL_GPIO_WritePin(GPIOB, LED_R_Pin, GPIO_PIN_SET);  // Allume D4 (PB_7)
  			  HAL_GPIO_WritePin(GPIOA, LED_B_Pin, GPIO_PIN_SET);   // Allume D9 (PA_8)
  			  HAL_GPIO_WritePin(GPIOB, LED_J_Pin, GPIO_PIN_SET);   // Allume D6 (PB_1)
  			  HAL_GPIO_WritePin(GPIOB, LED_V_Pin, GPIO_PIN_SET);   // Allume D5 (PB_6)

  			  HAL_Delay(fréquence[n]);

  			  HAL_GPIO_WritePin(GPIOB, LED_R_Pin, GPIO_PIN_RESET);  // Éteint D4 (PB_7)
  			  HAL_GPIO_WritePin(GPIOA, LED_B_Pin, GPIO_PIN_RESET);   // Éteint D9 (PA_8)
  			  HAL_GPIO_WritePin(GPIOB, LED_J_Pin, GPIO_PIN_RESET);   // Éteint D6 (PB_1)
  			  HAL_GPIO_WritePin(GPIOB, LED_V_Pin, GPIO_PIN_RESET);   // Éteint D5 (PB_6)

  			  HAL_Delay(fréquence[n]);
  		  }
    /* USER CODE END 3 */
  	  }
    }
  }
