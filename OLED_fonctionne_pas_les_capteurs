/* --- PROTOTYPES --- */
void SystemClock_Config(void);
static void MX_GPIO_Init(void);
static void MX_I2C1_Init(void);
static void MX_USART2_UART_Init(void);
void Error_Handler(void);

void OLED_Init(void);
void OLED_Clear(void);
void OLED_SetCursor(uint8_t x, uint8_t page);
void OLED_WriteStr(char* str);
void Sensors_Init(void);
void Read_Data(void);

int main(void)
{
  HAL_Init();
  SystemClock_Config();
  MX_GPIO_Init();
  MX_I2C1_Init();
  MX_USART2_UART_Init();

  HAL_Delay(500);
  OLED_Init();
  OLED_Clear(); // NETTOYAGE DE L'ÉCRAN ICI

  OLED_SetCursor(0, 0);
  OLED_WriteStr("CHECK SENSORS...");
  HAL_Delay(1000);

  // Vérification I2C
  if(HAL_I2C_IsDeviceReady(&hi2c1, BMP280_ADDR, 5, 100) != HAL_OK) {
      OLED_SetCursor(0, 2);
      OLED_WriteStr("BMP280 ERR");
  }
  if(HAL_I2C_IsDeviceReady(&hi2c1, ICM_ADDR, 5, 100) != HAL_OK) {
      OLED_SetCursor(0, 4);
      OLED_WriteStr("ICM20948 ERR");
  }

  Sensors_Init();
  HAL_Delay(1000);
  OLED_Clear();

  while (1)
  {
    Read_Data();

    OLED_SetCursor(0, 0);
    OLED_WriteStr("--- STATION ---");

    OLED_SetCursor(0, 2);
    sprintf(buffer, "TEMP: %.1f C  ", temp); // Espaces à la fin pour effacer les vieux chiffres
    OLED_WriteStr(buffer);

    OLED_SetCursor(0, 4);
    sprintf(buffer, "PRES: %.0f HPA ", press);
    OLED_WriteStr(buffer);

    OLED_SetCursor(0, 6);
    sprintf(buffer, "ROLL: %.1f    ", roll);
    OLED_WriteStr(buffer);

    HAL_GPIO_TogglePin(GPIOB, GPIO_PIN_3);
    HAL_Delay(500);
  }
}

/* --- FONCTIONS OLED AMÉLIORÉES --- */

void OLED_Clear(void) {
    uint8_t zero[128] = {0};
    for(uint8_t i=0; i<8; i++) {
        OLED_SetCursor(0, i);
        HAL_I2C_Mem_Write(&hi2c1, OLED_ADDR, 0x40, 1, zero, 128, 100);
    }
}

void OLED_SendCmd(uint8_t cmd) {
    HAL_I2C_Mem_Write(&hi2c1, OLED_ADDR, 0x00, 1, &cmd, 1, 10);
}

void OLED_Init(void) {
    uint8_t init[] = { 0xAE, 0x20, 0x00, 0xB0, 0xC8, 0x00, 0x10, 0x40, 0x81, 0x7F, 0xA1, 0xA6, 0xA8, 0x3F, 0xA4, 0xD3, 0x00, 0xD5, 0xF0, 0xD9, 0x22, 0xDA, 0x12, 0xDB, 0x20, 0x8D, 0x14, 0xAF };
    for(int i=0; i<sizeof(init); i++) OLED_SendCmd(init[i]);
}

void OLED_SetCursor(uint8_t x, uint8_t page) {
    OLED_SendCmd(0xB0 + page);
    OLED_SendCmd(0x00 + (x & 0x0F));
    OLED_SendCmd(0x10 + ((x >> 4) & 0x0F));
}

void OLED_WriteStr(char* str) {
    while(*str) {
        char c = *str++;
        uint8_t data[6] = {0}; // 5 pixels + 1 espace
        if(c >= 32 && c <= 126) {
            memcpy(data, font5x7[c-32], 5);
        }
        HAL_I2C_Mem_Write(&hi2c1, OLED_ADDR, 0x40, 1, data, 6, 10);
    }
}

/* --- RESTE DU CODE (SENSORS & CONFIG) --- */

void Sensors_Init(void) {
    uint8_t data = 0x01;
    HAL_I2C_Mem_Write(&hi2c1, ICM_ADDR, 0x06, 1, &data, 1, 100);
    data = 0x3F;
    HAL_I2C_Mem_Write(&hi2c1, BMP280_ADDR, 0xF4, 1, &data, 1, 100);
}

void Read_Data(void) {
    uint8_t raw[6];
    if(HAL_I2C_Mem_Read(&hi2c1, BMP280_ADDR, 0xF7, 1, raw, 6, 100) == HAL_OK) {
        int32_t p_raw = (raw[0] << 12) | (raw[1] << 4) | (raw[2] >> 4);
        int32_t t_raw = (raw[3] << 12) | (raw[4] << 4) | (raw[5] >> 4);
        temp = (float)t_raw / 16384.0f * 25.0f;
        press = (float)p_raw / 256.0f;
    }
    if(HAL_I2C_Mem_Read(&hi2c1, ICM_ADDR, 0x2D, 1, raw, 6, 100) == HAL_OK) {
        int16_t ay = (int16_t)(raw[2] << 8 | raw[3]);
        int16_t az = (int16_t)(raw[4] << 8 | raw[5]);
        roll = atan2f((float)ay, (float)az) * 57.3f;
    }
}

