/* --- CONFIGURATION --- */
I2C_HandleTypeDef hi2c1;
UART_HandleTypeDef huart2;

#define OLED_ADDR    (0x3C << 1)
#define BMP280_ADDR  (0x76 << 1) // Tentez 0x77 si ça reste à 0
#define ICM_ADDR     (0x68 << 1) // Tentez 0x69 si ça reste à 0

float temp = 0, press = 0, roll = 0;
char buffer[20];

/* --- POLICE (Ajout de l'espace ' ') --- */
const uint8_t font5x7[][5] = {
    [0] = {0x00, 0x00, 0x00, 0x00, 0x00}, // Espace
    ['A'-32]={0x7C,0x12,0x11,0x12,0x7C}, ['B'-32]={0x7F,0x49,0x49,0x49,0x36},
    ['C'-32]={0x3E,0x41,0x41,0x41,0x22}, ['D'-32]={0x7F,0x41,0x41,0x22,0x1C},
    ['E'-32]={0x7F,0x49,0x49,0x49,0x41}, ['L'-32]={0x7F,0x40,0x40,0x40,0x40},
    ['M'-32]={0x7F,0x02,0x0C,0x02,0x7F}, ['N'-32]={0x7F,0x04,0x08,0x10,0x7F},
    ['O'-32]={0x3E,0x41,0x41,0x41,0x3E}, ['P'-32]={0x7F,0x09,0x09,0x09,0x06},
    ['R'-32]={0x7F,0x09,0x19,0x29,0x46}, ['T'-32]={0x01,0x01,0x7F,0x01,0x01},
    ['S'-32]={0x46,0x49,0x49,0x49,0x31}, ['U'-32]={0x3F,0x40,0x40,0x40,0x3F},
    ['I'-32]={0x00,0x41,0x7F,0x41,0x00}, ['V'-32]={0x1F,0x20,0x40,0x20,0x1F},
    ['0'-32]={0x3E,0x51,0x49,0x45,0x3E}, ['1'-32]={0x00,0x42,0x7F,0x40,0x00},
    ['2'-32]={0x42,0x61,0x51,0x49,0x46}, ['3'-32]={0x21,0x41,0x45,0x4B,0x31},
    ['4'-32]={0x18,0x14,0x12,0x7F,0x10}, ['5'-32]={0x27,0x45,0x45,0x45,0x39},
    ['6'-32]={0x3C,0x4A,0x49,0x49,0x30}, ['7'-32]={0x01,0x71,0x09,0x05,0x03},
    ['8'-32]={0x36,0x49,0x49,0x49,0x36}, ['9'-32]={0x06,0x49,0x49,0x29,0x1E},
