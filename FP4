/* ===== OLED SSD1306 ===== */
void OLED_SendCmd(uint8_t cmd) {
    HAL_I2C_Mem_Write(&hi2c1, OLED_ADDR, 0x00, 1, &cmd, 1, 10);
}

void OLED_Init(void) {
    HAL_Delay(100);
    uint8_t cmds[] = {
        0xAE, 0x20, 0x00, 0xB0, 0xC8, 0x00, 0x10, 0x40,
        0x81, 0x7F, 0xA1, 0xA6, 0xA8, 0x3F, 0xA4,
        0xD3, 0x00, 0xD5, 0xF0, 0xD9, 0x22,
        0xDA, 0x12, 0xDB, 0x20, 0x8D, 0x14, 0xAF
    };
    for (int i = 0; i < (int)sizeof(cmds); i++) OLED_SendCmd(cmds[i]);
}

void OLED_SetCursor(uint8_t x, uint8_t page) {
    OLED_SendCmd(0xB0 + page);
    OLED_SendCmd(0x00 + (x & 0x0F));
    OLED_SendCmd(0x10 + ((x >> 4) & 0x0F));
}

void OLED_Clear(void) {
    uint8_t zero[128] = {0};
    for (uint8_t i = 0; i < 8; i++) {
        OLED_SetCursor(0, i);
        HAL_I2C_Mem_Write(&hi2c1, OLED_ADDR, 0x40, 1, zero, 128, 100);
    }
}

void OLED_WriteStr(char* str) {
    while (*str) {
        char c = *str++;
        uint8_t data[6] = {0};
        if (c >= 32 && c <= 90)
            memcpy(data, font5x7[c - 32], 5);
        HAL_I2C_Mem_Write(&hi2c1, OLED_ADDR, 0x40, 1, data, 6, 10);
    }
}

/* ===== BMP280 ===== */
static uint16_t dig_T1, dig_P1;
static int16_t  dig_T2, dig_T3;
static int16_t  dig_P2, dig_P3, dig_P4, dig_P5, dig_P6, dig_P7, dig_P8, dig_P9;
static int32_t  t_fine;

void BMP280_Init(void) {
    uint8_t rst = 0xB6;
    HAL_I2C_Mem_Write(&hi2c1, BMP280_ADDR, 0xE0, 1, &rst, 1, 100);
    HAL_Delay(100);

    uint8_t config = 0xA0; // standby 1000ms, filtre x4
    uint8_t ctrl   = 0xB7; // osrs_t x4, osrs_p x16, mode normal
    HAL_I2C_Mem_Write(&hi2c1, BMP280_ADDR, 0xF5, 1, &config, 1, 100);
    HAL_I2C_Mem_Write(&hi2c1, BMP280_ADDR, 0xF4, 1, &ctrl,   1, 100);
    HAL_Delay(300);

    uint8_t cal[24];
    HAL_I2C_Mem_Read(&hi2c1, BMP280_ADDR, 0x88, 1, cal, 24, 100);
    dig_T1 = (uint16_t)(cal[1]  << 8 | cal[0]);
    dig_T2 = (int16_t) (cal[3]  << 8 | cal[2]);
    dig_T3 = (int16_t) (cal[5]  << 8 | cal[4]);
    dig_P1 = (uint16_t)(cal[7]  << 8 | cal[6]);
    dig_P2 = (int16_t) (cal[9]  << 8 | cal[8]);
    dig_P3 = (int16_t) (cal[11] << 8 | cal[10]);
    dig_P4 = (int16_t) (cal[13] << 8 | cal[12]);
    dig_P5 = (int16_t) (cal[15] << 8 | cal[14]);
    dig_P6 = (int16_t) (cal[17] << 8 | cal[16]);
    dig_P7 = (int16_t) (cal[19] << 8 | cal[18]);
    dig_P8 = (int16_t) (cal[21] << 8 | cal[20]);
    dig_P9 = (int16_t) (cal[23] << 8 | cal[22]);
}

void BMP280_Read(void) {
    uint8_t status;
    uint32_t timeout = HAL_GetTick();
    do {
        HAL_I2C_Mem_Read(&hi2c1, BMP280_ADDR, 0xF3, 1, &status, 1, 10);
    } while ((status & 0x08) && (HAL_GetTick() - timeout < 100));

    uint8_t raw[6];
    HAL_I2C_Mem_Read(&hi2c1, BMP280_ADDR, 0xF7, 1, raw, 6, 100);

    int32_t adc_P = (int32_t)((raw[0] << 12) | (raw[1] << 4) | (raw[2] >> 4));
    int32_t adc_T = (int32_t)((raw[3] << 12) | (raw[4] << 4) | (raw[5] >> 4));

    int32_t var1 = ((((adc_T >> 3) - ((int32_t)dig_T1 << 1))) * dig_T2) >> 11;
    int32_t var2 = (((((adc_T >> 4) - (int32_t)dig_T1) *
                      ((adc_T >> 4) - (int32_t)dig_T1)) >> 12) * dig_T3) >> 14;
    t_fine = var1 + var2;
    temp = (float)((t_fine * 5 + 128) >> 8) / 100.0f;

    int64_t p1 = (int64_t)t_fine - 128000;
    int64_t p2 = p1 * p1 * (int64_t)dig_P6;
    p2 += (p1 * (int64_t)dig_P5) << 17;
    p2 += ((int64_t)dig_P4) << 35;
    p1  = ((p1 * p1 * (int64_t)dig_P3) >> 8) + ((p1 * (int64_t)dig_P2) << 12);
    p1  = (((int64_t)1 << 47) + p1) * (int64_t)dig_P1 >> 33;
    if (p1 == 0) { press = 0; return; }
    int64_t p = 1048576 - adc_P;
    p = (((p << 31) - p2) * 3125) / p1;
    p1 = ((int64_t)dig_P9 * (p >> 13) * (p >> 13)) >> 25;
    p2 = ((int64_t)dig_P8 * p) >> 19;
    p  = ((p + p1 + p2) >> 8) + ((int64_t)dig_P7 << 4);
    press = (float)p / 25600.0f;
}

/* ===== ICM-20948 ===== */
void ICM20948_Init(void) {
    uint8_t d;
    d = 0x00; HAL_I2C_Mem_Write(&hi2c1, ICM_ADDR, 0x7F, 1, &d, 1, 100); // banque 0
    d = 0x01; HAL_I2C_Mem_Write(&hi2c1, ICM_ADDR, 0x06, 1, &d, 1, 100); // sortie sleep
    HAL_Delay(10);
    d = 0x00; HAL_I2C_Mem_Write(&hi2c1, ICM_ADDR, 0x14, 1, &d, 1, 100); // accel ±2g
    d = 0x00; HAL_I2C_Mem_Write(&hi2c1, ICM_ADDR, 0x01, 1, &d, 1, 100); // gyro ±250°/s
}

void ICM20948_Read(void) {
    uint8_t raw[6], graw[6];

    /* Accéléromètre */
    HAL_I2C_Mem_Read(&hi2c1, ICM_ADDR, 0x2D, 1, raw, 6, 100);
    int16_t ax = (int16_t)(raw[0] << 8 | raw[1]);
    int16_t ay = (int16_t)(raw[2] << 8 | raw[3]);
    int16_t az = (int16_t)(raw[4] << 8 | raw[5]);

    /* Gyroscope */
    HAL_I2C_Mem_Read(&hi2c1, ICM_ADDR, 0x33, 1, graw, 6, 100);
    int16_t gz = (int16_t)(graw[4] << 8 | graw[5]);

    /* Roulis et tangage depuis accéléromètre */
    roll  = atan2f((float)ay, (float)az) * 57.2958f;
    pitch = atan2f(-(float)ax, sqrtf((float)ay*(float)ay + (float)az*(float)az)) * 57.2958f;

    /* Lacet par intégration gyroscope */
    static uint32_t last_tick = 0;
    if (last_tick == 0) last_tick = HAL_GetTick();
    uint32_t now = HAL_GetTick();
    float dt = (now - last_tick) / 1000.0f;
    last_tick = now;
    float gz_dps = (float)gz / 131.0f;
    if (fabsf(gz_dps) < 1.0f) gz_dps = 0.0f;
    yaw += gz_dps * dt;
}
