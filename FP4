/**
  * @brief  The application entry point.
  * @retval int
  */
int main(void)
{
  /* USER CODE BEGIN 1 */
  /* USER CODE END 1 */

  /* MCU Configuration--------------------------------------------------------*/
  HAL_Init();

  /* Configure the system clock */
  SystemClock_Config();

  /* Initialize all configured peripherals */
  MX_GPIO_Init();
  MX_USART2_UART_Init();
  MX_SPI1_Init();
  MX_FATFS_Init();
  MX_TIM2_Init();
  MX_I2C1_Init();

  /* USER CODE BEGIN 2 */
  HAL_Delay(200);
  OLED_Init();
  OLED_Clear();
  BMP280_Init();
  ICM20948_Init();

  /* Démarrage de la PWM pour le servomoteur (FP4) */
  HAL_TIM_PWM_Start(&htim2, TIM_CHANNEL_2);
  __HAL_TIM_MOE_ENABLE(&htim2);

  OLED_SetCursor(0, 0);
  OLED_WriteStr("INIT OK");
  HAL_Delay(500);
  OLED_Clear();

  /* Initialisation et montage de la carte SD (FP2) */
  fres = f_mount(&fs, "", 1);
  sprintf(msg, "f_mount: %d\r\n", fres);
  HAL_UART_Transmit(&huart2, (uint8_t*)msg, strlen(msg), 100);

  fres = f_open(&fil, "data.csv", FA_WRITE | FA_CREATE_ALWAYS);
  sprintf(msg, "f_open: %d\r\n", fres);
  HAL_UART_Transmit(&huart2, (uint8_t*)msg, strlen(msg), 100);

  if (fres == FR_OK) {
      f_printf(&fil, "TEMP,PRESS,ROLL,PITCH,YAW\n");
  }

  /* Test d'initialisation du servomoteur (FP4) */
  __HAL_TIM_SET_COMPARE(&htim2, TIM_CHANNEL_2, 1500); // Centre
  HAL_Delay(500);
  __HAL_TIM_SET_COMPARE(&htim2, TIM_CHANNEL_2, 1000); // Gauche
  HAL_Delay(500);
  __HAL_TIM_SET_COMPARE(&htim2, TIM_CHANNEL_2, 2000); // Droite
  HAL_Delay(500);

  ICM20948_Read();
  yaw = 0.0f;

  /* USER CODE END 2 */

  /* Infinite loop */
  /* USER CODE BEGIN WHILE */
  while (1)
  {
      /* USER CODE END WHILE */

      /* USER CODE BEGIN 3 */

      /* --- 1. LECTURE DES CAPTEURS --- */
      BMP280_Read();
      ICM20948_Read();

      /* --- 2. GESTION DU SERVOMOTEUR DE LACET (FP4) --- */
      float yaw_clamped = yaw;
      if (yaw_clamped >  45.0f) yaw_clamped =  45.0f;
      if (yaw_clamped < -45.0f) yaw_clamped = -45.0f;

      // Calcul du signal PWM (1000 µs à 2000 µs pour -45° à +45°)
      uint32_t pulse_us = (uint32_t)(1500.0f + (yaw_clamped / 45.0f) * 500.0f);
      __HAL_TIM_SET_COMPARE(&htim2, TIM_CHANNEL_2, pulse_us);

      /* --- 3. AFFICHAGE ÉCRAN OLED EN DEGRÉS (FP1) --- */
      OLED_SetCursor(0, 0);
      sprintf(msg, "TEMP: %.1fC   ", temp);
      OLED_WriteStr(msg);

      OLED_SetCursor(0, 2);
      sprintf(msg, "PRES: %.1fHPA ", press);
      OLED_WriteStr(msg);

      OLED_SetCursor(0, 4);
      sprintf(msg, "ROLL: %.1f DEG", roll);
      OLED_WriteStr(msg);

      OLED_SetCursor(0, 6);
      sprintf(msg, "PTCH: %.1f DEG", pitch);
      OLED_WriteStr(msg);

      /* --- 4. ENVOI TERMINAL SÉRIE UART (FP1) --- */
      sprintf(msg, "T=%.1f C, P=%.1f hPa, R=%.1f, Pi=%.1f, Y=%.1f\r\n",
              temp, press, roll, pitch, yaw);
      HAL_UART_Transmit(&huart2, (uint8_t*)msg, strlen(msg), 100);

      /* --- 5. ENREGISTREMENT SUR LA CARTE MICROSD (FP2) --- */
      if (fres == FR_OK) {
          char line[64];
          sprintf(line, "%.1f,%.1f,%.1f,%.1f,%.1f\n",
                  temp, press, roll, pitch, yaw);
          f_puts(line, &fil);
          f_sync(&fil);
      }

      /* --- 6. CADENCE À 5 Hz (FP1) --- */
      HAL_GPIO_TogglePin(GPIOB, LD3_Pin); // LED témoin d'activité
      HAL_Delay(200);                    // 200 ms d'attente = cycle à 5 Hz
  }
  /* USER CODE END 3 */
}

